# Gemini / Google Cloud configuration.
# Copy this file to .env and fill in project-specific values.

HYPER_ADK_MODEL=gemini-3.5-flash
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

# Cloud Run / Agent Runtime deployment region. This is separate from the Gemini
# model-serving location above.
HYPER_ADK_DEPLOY_REGION=asia-south1

# Local artifact root for smoke-run manifests and generated reports.
HYPER_ADK_ARTIFACT_ROOT=./artifacts

# Default bundled smoke dataset. The project uses synthetic sample data for
# reviewer tests; the full research dataset is intentionally not included.
HYPER_ADK_DEFAULT_DATASET=sp500_smoke

# Expensive or risky actions are disabled by default. Public demos should keep
# both flags false.
HYPER_ADK_ENABLE_LIVE_RUNS=false
HYPER_ADK_ENABLE_GENERATED_CODE=false
